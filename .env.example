# =====================================================================
# Mainline Hub — Environment Variables
# =====================================================================
# Copy this file to `.env.local` (which is gitignored) and fill in
# the real values. Never commit `.env.local` or any file containing
# real keys to git.
#
# For Vercel deployment, add the same variables under
# Project Settings -> Environment Variables. Use the *_TEST_* values
# for Preview environments and *_LIVE_* values for Production.
# =====================================================================


# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
# Public URL of the site. In local dev this is http://localhost:3000.
# In Vercel, set this to your custom domain (e.g. https://mainlinehub.com).
NEXT_PUBLIC_URL=http://localhost:3000

# Display name used in titles and emails.
NEXT_PUBLIC_STORE_NAME=Mainline Hub


# ---------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------
# From Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...                # "anon public" key

# Service-role key. SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...


# ---------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------
# Use TEST keys (pk_test_..., sk_test_...) for local dev and Vercel
# Preview deploys. Use LIVE keys (pk_live_..., sk_live_...) ONLY for
# the Production environment in Vercel, after end-to-end testing.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret. You get this when you create a webhook
# endpoint in the Stripe dashboard, OR from `stripe listen` output
# during local dev.
STRIPE_WEBHOOK_SECRET=whsec_...


# ---------------------------------------------------------------------
# Printify
# ---------------------------------------------------------------------
# Personal access token from Printify -> My Profile -> Connections.
PRINTIFY_API_KEY=eyJ0eXAi...

# Your Printify shop ID. To find it, run:
#   curl -H "Authorization: Bearer $PRINTIFY_API_KEY" \
#        https://api.printify.com/v1/shops.json
# and copy the numeric `id` of the shop you want to use.
PRINTIFY_SHOP_ID=1234567

# Webhook secret used to verify incoming Printify webhook signatures.
# Generate any random string (e.g. `openssl rand -hex 32`) and supply
# the same value when registering the webhook in the Printify
# dashboard. Required for production.
PRINTIFY_WEBHOOK_SECRET=replace-with-random-hex


# ---------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------
# API key from https://resend.com -> API Keys.
RESEND_API_KEY=re_...

# The "From" address for transactional email. Must be on a domain
# verified in Resend (use `onboarding@resend.dev` for local dev only).
RESEND_FROM_EMAIL=Mainline Hub <orders@yourdomain.com>


# ---------------------------------------------------------------------
# Admin bootstrap (optional, for first deploy only)
# ---------------------------------------------------------------------
# If set, the seed script will promote this email to `admin` role
# the first time it runs. Leave blank after the first admin exists.
ADMIN_BOOTSTRAP_EMAIL=
